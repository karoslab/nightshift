{
  "name": "nightshift-qa",
  "version": "0.1.0",
  "description": "The overnight QA employee you run on your own machine, with your own Claude. Explores your web app, finds bugs, and only files the ones it can deterministically reproduce.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "bin": {
    "nightshift": "bin/nightshift.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin/",
    "lib/",
    "console/",
    "demo-app/",
    "examples/",
    "README.md",
    "TERMS.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "demo": "node bin/nightshift.mjs demo",
    "console": "node console/server.mjs"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  }
}
